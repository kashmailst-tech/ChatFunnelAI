rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isIncrementingViews() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1;
    }
    
    function isIncrementingLeads() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['leads']) && request.resource.data.leads == resource.data.leads + 1;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'email', 'plan', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.email is string &&
             request.resource.data.plan in ['free', 'pro', 'business'] &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidFunnel() {
      return hasRequiredFields(['id', 'userId', 'name', 'slug', 'whatsappNumber', 'createdAt']) &&
             request.resource.data.id is string &&
             request.resource.data.userId is string &&
             request.resource.data.name is string &&
             request.resource.data.slug is string &&
             request.resource.data.whatsappNumber is string &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidLead() {
      return hasRequiredFields(['funnelId', 'userId', 'data', 'createdAt']) &&
             request.resource.data.funnelId is string &&
             request.resource.data.userId is string &&
             request.resource.data.data is map &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /funnels/{funnelId} {
      // Allow read if owner, or if public (we might need public read for the funnel landing page)
      // For now, let's allow public read for funnels so visitors can see them.
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidFunnel();
      allow update: if (isDocOwner() && request.resource.data.userId == resource.data.userId && isValidFunnel()) || isIncrementingViews() || isIncrementingLeads();
      allow delete: if isDocOwner();
    }

    match /leads/{leadId} {
      // Allow public create so visitors can submit leads
      allow create: if isValidLead();
      // Only owner of the funnel can read/update/delete leads
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
